@page "/envelope/{TrackId:guid}"
@using TheaterCue.Application
@using TheaterCue.Domain
@implements IAsyncDisposable
@inject IAudioEngine AudioEngine
@inject NavigationManager Nav
@inject ShowStateService ShowState

<div class="envelope-editor">
    <div class="envelope-editor__toolbar">
        <button @onclick="OnBack">← Volver</button>
        <span class="envelope-editor__title">@_trackName — Editor de Automatización</span>
        <button @onclick="OnClearEnvelope">🗑 Limpiar curva</button>
    </div>

    <div class="envelope-editor__canvas-container">
        <svg class="envelope-svg"
             xmlns="http://www.w3.org/2000/svg"
             xmlns:svg="http://www.w3.org/2000/svg"
             viewBox="0 0 @SvgWidth @SvgHeight"
             @onmousedown="OnSvgMouseDown"
             @onmousemove="OnSvgMouseMove"
             @onmouseup="OnSvgMouseUp"
             @onmouseleave="OnSvgMouseUp">

            <!-- Grilla de fondo -->
            @for (int i = 0; i <= 4; i++)
            {
                var y = i * (SvgHeight / 4.0);
                var label = (1.0 - i / 4.0).ToString("P0");
                <line x1="0" y1="@y" x2="@SvgWidth" y2="@y"
                      stroke="#333" stroke-width="1" />
                <svg:text x="4" y="@(y - 4)" fill="#666" font-size="10">@label</svg:text>
            }

            <!-- Curva interpolada -->
            @if (_curvePoints.Count > 1)
            {
                <polyline points="@_curvePointsStr"
                          fill="none" stroke="#00c853" stroke-width="2" />
            }

            <!-- Área bajo la curva -->
            @if (_curvePoints.Count > 1)
            {
                <polygon points="@_areaPointsStr"
                         fill="#00c85322" />
            }

            <!-- Línea de conexión entre nodos -->
            @foreach (var seg in _segments)
            {
                <line x1="@seg.x1" y1="@seg.y1" x2="@seg.x2" y2="@seg.y2"
                      stroke="#00c853" stroke-width="1.5" stroke-dasharray="4,2" />
            }

            <!-- Nodos -->
            @foreach (var node in _envelope.Nodes)
            {
                var cx = TimeToX(node.Time);
                var cy = VolumeToY(node.Volume);
                <circle cx="@cx" cy="@cy" r="7"
                        fill="@(_draggedNode == node ? "#ffd600" : "#00c853")"
                        stroke="white" stroke-width="2"
                        style="cursor: grab"
                        @onmousedown:stopPropagation="true"
                        @onmousedown="(e) => OnNodeMouseDown(e, node)"
                        @ondblclick="() => OnNodeDoubleClick(node)" />
            }

            <!-- Cabezal de reproducción -->
            @if (_snapshot.Duration.TotalSeconds > 0)
            {
                var headX = TimeToX(_snapshot.CurrentTime);
                <line x1="@headX" y1="0" x2="@headX" y2="@SvgHeight"
                      stroke="#ff4444" stroke-width="2" />
                <polygon points="@headX,0 @(headX - 6),0 @(headX + 6),0 @headX,12"
                         fill="#ff4444" />
            }
        </svg>
    </div>

    <div class="envelope-editor__hint">
        Click para agregar nodo · Doble click en nodo para eliminarlo · Arrastra para mover
    </div>
</div>

@code {
    [Parameter] public Guid TrackId { get; set; }

    // ── Constantes del SVG ───────────────────────────────────────────
    private const double SvgWidth = 800;
    private const double SvgHeight = 300;

    // ── Estado ──────────────────────────────────────────────────────
    private VolumeEnvelope _envelope = VolumeEnvelope.Empty;
    private PlaybackSnapshot _snapshot = PlaybackSnapshot.NotLoaded;
    private string _trackName = string.Empty;

    // Curva interpolada precalculada para el <polyline>
    private List<(double x, double y)> _curvePoints = [];
    private string _curvePointsStr = string.Empty;
    private string _areaPointsStr = string.Empty;
    private List<(double x1, double y1, double x2, double y2)> _segments = [];

    // Drag & drop
    private AutomationNode? _draggedNode = null;

    // Timer de 30fps (igual que CuePlayerCard)
    private PeriodicTimer? _timer;
    private CancellationTokenSource _cts = new();

    // ── Ciclo de vida ────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        var track = ShowState.Tracks.FirstOrDefault(t => t.Id == TrackId);
        _trackName = track?.Name ?? "Pista desconocida";
        _envelope = track?.Envelope ?? VolumeEnvelope.Empty;
        RebuildCurve();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(33));
        try
        {
            while (await _timer.WaitForNextTickAsync(_cts.Token))
            {
                _snapshot = AudioEngine.GetSnapshot(TrackId);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    // ── Coordenadas ─────────────────────────────────────────────────
    private double TimeToX(TimeSpan time)
    {
        if (_snapshot.Duration.TotalSeconds <= 0) return 0;
        return time.TotalSeconds / _snapshot.Duration.TotalSeconds * SvgWidth;
    }

    private double VolumeToY(float volume)
        => SvgHeight - volume * SvgHeight;

    private TimeSpan XToTime(double x)
    {
        if (_snapshot.Duration.TotalSeconds <= 0) return TimeSpan.Zero;
        var seconds = x / SvgWidth * _snapshot.Duration.TotalSeconds;
        return TimeSpan.FromSeconds(Math.Clamp(seconds, 0, _snapshot.Duration.TotalSeconds));
    }

    private float YToVolume(double y)
        => (float)Math.Clamp(1.0 - y / SvgHeight, 0.0, 1.0);

    // ── Construcción de la curva ─────────────────────────────────────
    private void RebuildCurve()
    {
        _curvePoints.Clear();
        _segments.Clear();

        if (_snapshot.Duration.TotalSeconds <= 0)
        {
            _curvePointsStr = string.Empty;
            _areaPointsStr = string.Empty;
            return;
        }

        // Samplear la envolvente en 200 puntos para la polyline
        int steps = 200;
        for (int i = 0; i <= steps; i++)
        {
            var t = TimeSpan.FromSeconds(i / (double)steps * _snapshot.Duration.TotalSeconds);
            var x = TimeToX(t);
            var y = VolumeToY(_envelope.GetVolumeAt(t));
            _curvePoints.Add((x, y));
        }

        _curvePointsStr = string.Join(" ", _curvePoints.Select(p => $"{p.x:F1},{p.y:F1}"));

        // Área bajo la curva (cerrar el polígono por abajo)
        var area = _curvePoints.ToList();
        area.Add((SvgWidth, SvgHeight));
        area.Add((0, SvgHeight));
        _areaPointsStr = string.Join(" ", area.Select(p => $"{p.x:F1},{p.y:F1}"));

        // Segmentos entre nodos para la línea punteada
        var nodes = _envelope.Nodes.ToList();
        for (int i = 0; i < nodes.Count - 1; i++)
        {
            _segments.Add((
                TimeToX(nodes[i].Time), VolumeToY(nodes[i].Volume),
                TimeToX(nodes[i + 1].Time), VolumeToY(nodes[i + 1].Volume)
            ));
        }
    }

    // ── Eventos del SVG ──────────────────────────────────────────────
    private void OnSvgMouseDown(MouseEventArgs e)
    {
        // Click en área vacía → agregar nodo
        var time = XToTime(e.OffsetX);
        var volume = YToVolume(e.OffsetY);
        _envelope = _envelope.WithNode(new AutomationNode(time, volume));
        AudioEngine.SetEnvelope(TrackId, _envelope);
        RebuildCurve();
    }

    private void OnSvgMouseMove(MouseEventArgs e)
    {
        if (_draggedNode is null) return;

        var time = XToTime(e.OffsetX);
        var volume = YToVolume(e.OffsetY);

        _envelope = _envelope.WithoutNodeAt(_draggedNode.Time)
                                 .WithNode(new AutomationNode(time, volume));
        _draggedNode = new AutomationNode(time, volume);
        AudioEngine.SetEnvelope(TrackId, _envelope);
        RebuildCurve();
    }

    private void OnSvgMouseUp(MouseEventArgs e)
        => _draggedNode = null;

    private void OnNodeMouseDown(MouseEventArgs e, AutomationNode node)
        => _draggedNode = node;

    private void OnNodeDoubleClick(AutomationNode node)
    {
        _envelope = _envelope.WithoutNodeAt(node.Time);
        AudioEngine.SetEnvelope(TrackId, _envelope);
        RebuildCurve();
    }

    // ── Toolbar ──────────────────────────────────────────────────────
    private void OnClearEnvelope()
    {
        _envelope = VolumeEnvelope.Empty;
        AudioEngine.SetEnvelope(TrackId, _envelope);
        RebuildCurve();
    }

    private void OnBack()
        => Nav.NavigateTo("/");

    // ── Dispose ──────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _timer?.Dispose();
    }
}