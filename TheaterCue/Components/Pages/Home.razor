@page "/"
@using TheaterCue.Components.Modals
@using TheaterCue.Domain
@using TheaterCue.Application
@inject IProjectRepository ProjectRepository
@inject ShowStateService ShowState
@inject IAudioEngine AudioEngine
@inject CommunityToolkit.Maui.Storage.IFileSaver FileSaver

<div class="home-toolbar">
    <div class="toolbar-left">
        <button title="Nuevo proyecto" @onclick="() => _confirmNewProject = true">🔄 Nuevo</button>
        <button title="Agregar pista de música" @onclick="() => OnAddTrack(0)">＋ Música</button>
        <button title="Agregar efecto de sonido" @onclick="() => OnAddTrack(1)">＋ SFX</button>
        <button title="Guardar proyecto" @onclick="OnSaveProject">💾 Guardar</button>
        <button title="Abrir proyecto" @onclick="OnOpenProject"><i class="bi bi-folder2-open"></i> Abrir</button>
        <a href="/manual" class="btn" title="Manual de usuario">?</a>
        <button @onclick="() => welcomeGuide?.Show()">Guía</button>
        <WelcomeGuide @ref="welcomeGuide" />
        <button title="Ajustes Globales"
                class="@(_showGlobalSettings ? "btn-active" : "")"
                @onclick="() => _showGlobalSettings = !_showGlobalSettings">
            ⚙ Ajustes
        </button>
    </div>
    <ConfirmDialog Visible="_confirmNewProject"
                   Message="¿Crear nuevo proyecto? Se perderán los cambios no guardados."
                   ConfirmLabel="Nuevo proyecto"
                   OnConfirm="ConfirmNewProject"
                   OnCancel="() => _confirmNewProject = false" />

    <div class="toolbar-center">
        @if (ShowState.ProjectName is not null)
        {
            <span class="toolbar-project-name">@ShowState.ProjectName</span>
        }
    </div>

    <div class="toolbar-right">
        <span class="device-label">🔊</span>
        <select title="Dispositivo de salida de audio"
                value="@_selectedDeviceId"
                @onchange="OnDeviceChanged"
                class="device-selector">
            @foreach (var device in _devices)
            {
                <option value="@device.Id">@device.Name</option>
            }
        </select>
    </div>
</div>

@if (_showGlobalSettings)
{
    <div class="cue-modal-overlay" @onclick="() => _showGlobalSettings = false">
        <div class="cue-modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>⚙ Ajustes Globales del Show</h3>
                <button class="modal-close" @onclick="() => _showGlobalSettings = false">✕</button>
            </div>

            <div class="settings-grid">
                <div class="setting-item">
                    <label>Fade In Global (segundos)</label>
                    <input type="number" min="0.5" max="60" step="0.5"
                           @bind="ShowState.GlobalFadeInSeconds" />
                </div>
                <div class="setting-item">
                    <label>Fade Out Global (segundos)</label>
                    <input type="number" min="0.5" max="60" step="0.5"
                           @bind="ShowState.GlobalFadeOutSeconds" />
                </div>
            </div>

            <div class="modal-actions">
                <button @onclick="() => _showGlobalSettings = false">✓ Listo</button>
            </div>
        </div>
    </div>
}

@if (_envelopeTrackId.HasValue)
{
    <EnvelopeModal TrackId="_envelopeTrackId.Value"
                   OnClose="() => _envelopeTrackId = null" />
}

<CueGrid Tracks="ShowState.Tracks"
         OnRemove="OnRemoveTrack"
         OnOpenEnvelope="(id) => _envelopeTrackId = id" />

@code {
    private bool _showGlobalSettings = false;
    private List<AudioDeviceInfo> _devices = [];
    private bool _confirmNewProject = false;
    private WelcomeGuide? welcomeGuide;

    private string? _selectedDeviceId = null;

    protected override void OnInitialized()
    {
        _devices = AudioEngine.GetOutputDevices().ToList();
        _selectedDeviceId = AudioEngine.CurrentDeviceId ?? _devices.FirstOrDefault()?.Id;
        AudioEngine.OutputDevicesChanged += OnOutputDevicesChanged;
    }

    private void OnOutputDevicesChanged()
    {
        InvokeAsync(() =>
        {
            _devices = AudioEngine.GetOutputDevices().ToList();

            // Si el dispositivo actual ya no existe, resetear al default
            if (!_devices.Any(d => d.Id == _selectedDeviceId))
            {
                _selectedDeviceId = _devices.FirstOrDefault()?.Id;
                if (_selectedDeviceId is not null)
                    AudioEngine.SetOutputDevice(_selectedDeviceId);
            }

            StateHasChanged();
        });
    }

    private void OnDeviceChanged(ChangeEventArgs e)
    {
        var deviceId = e.Value?.ToString();
        if (string.IsNullOrEmpty(deviceId)) return;
        _selectedDeviceId = deviceId;
        AudioEngine.SetOutputDevice(deviceId);
    }

    private void OnNewProject()
    {
        // Descarga todos los tracks activos del engine
        foreach (var track in ShowState.Tracks)
            AudioEngine.UnloadTrack(track.Id);

        ShowState.Tracks = [];
        ShowState.ProjectName = "Nuevo Show";
        ShowState.CurrentFilePath = null;
    }

    private void OnAddTrack(int column)
    {
        var row = ShowState.Tracks.Count(t => t.Position.Column == column);
        ShowState.Tracks.Add(new CueTrack
        {
            Id = Guid.NewGuid(),
            Name = column == 0 ? "Nueva Música" : "Nuevo SFX",
            FilePath = string.Empty,
            Position = new GridPosition(row, column)
        });
    }

    private void OnRemoveTrack(Guid trackId)
    {
        AudioEngine.UnloadTrack(trackId);
        var track = ShowState.Tracks.FirstOrDefault(t => t.Id == trackId);
        if (track is not null)
            ShowState.Tracks.Remove(track);
    }

    private async Task OnSaveProject()
    {
        var project = new ShowProject
        {
            Name = ShowState.ProjectName,
            Tracks = ShowState.Tracks,
            // --- NUEVO ---
            GlobalFadeInSeconds = ShowState.GlobalFadeInSeconds,
            GlobalFadeOutSeconds = ShowState.GlobalFadeOutSeconds
        };

        var json = System.Text.Json.JsonSerializer.Serialize(project,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

        using var stream = new MemoryStream(System.Text.Encoding.UTF8.GetBytes(json));

        var result = await FileSaver.SaveAsync(
            ShowState.ProjectName + ".cueshow",
            stream,
            CancellationToken.None);

        if (result.IsSuccessful)
        {
            ShowState.CurrentFilePath = result.FilePath;
        }
    }

    private async Task OnOpenProject()
    {
        var result = await FilePicker.PickAsync(PickOptions.Default);
        if (result is null) return;

        try
        {
            var project = await ProjectRepository.LoadAsync(result.FullPath);

            foreach (var track in ShowState.Tracks)
                AudioEngine.UnloadTrack(track.Id);

            // Nueva instancia de lista para forzar re-render completo
            ShowState.Tracks = project.Tracks.ToList();

            // EL FIX: Leer el nombre del archivo sin el ".cueshow" en lugar de project.Name
            ShowState.ProjectName = Path.GetFileNameWithoutExtension(result.FullPath);

            ShowState.CurrentFilePath = result.FullPath;

            // --- NUEVO ---
            ShowState.GlobalFadeInSeconds = project.GlobalFadeInSeconds;
            ShowState.GlobalFadeOutSeconds = project.GlobalFadeOutSeconds;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR al abrir proyecto: {ex.GetType().Name}: {ex.Message}");
        }
    }

    private Guid? _envelopeTrackId = null;

    public void Dispose()
    {
        AudioEngine.OutputDevicesChanged -= OnOutputDevicesChanged;
    }
    private void ConfirmNewProject()
    {
        _confirmNewProject = false;
        OnNewProject();
    }
}